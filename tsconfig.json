{
	"compilerOptions": {
		"baseUrl": "./",
		"target": "ESNext",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"lib": ["ESNext", "DOM"],
		"moduleResolution": "Node",
		"strict": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"noEmit": true,
		"skipLibCheck": true,
		"jsx": "preserve",
		"jsxImportSource": "frame3",
		"paths": {
			"~/*": ["src/*"]
		}
	},
	"include": ["src"]
}
